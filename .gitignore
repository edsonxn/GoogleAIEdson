# ── Entorno ───────────────────────────────────────────────
.env
settings.json
styles.json

# ── Dependencias ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── Sistema operativo ─────────────────────────────────────
.DS_Store
Thumbs.db
$RECYCLE.BIN/
Desktop.ini
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
*~

# ── IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs y temporales ─────────────────────────────────────
logs/
*.log
temp/
tmp/
*.tmp
.cache/
.parcel-cache/

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.so
*.egg
*.egg-info/
build/
dist/

# ── Modelos de IA (grandes, se descargan automáticamente) ──
whisper_models/
*.bin
*.onnx

# ── Binarios de FFmpeg (se instalan localmente) ───────────
*.exe
*.dll

# ── Videos generados por Remotion/HolaVideo ───────────────
holavideo/out/*.mp4
holavideo/out/*.webm
holavideo/out/history.json

# ── Assets de entidades descargados (imágenes temporales) ─
holavideo/public/entity_*.jpg
holavideo/public/entity_*.png
holavideo/public/entity_*.webp
holavideo/public/person_*.jpg
holavideo/public/person_*.png
holavideo/public/person_*.webp
holavideo/public/entity_*.svg

# ── Proyectos de usuario (datos personales/privados) ──────
projects/
E:/outputs/

# ── Clips de broll generados dentro de proyectos ──────────
**/broll_ai_clips/
**/_broll_render_temp/
**/broll_thumbs/
**/broll_preview.json

# ── Audios de TTS generados ───────────────────────────────
**/seccion_*/audio_*.mp3
**/seccion_*/audio_*.wav
**/seccion_*/tts_*.mp3

# ── Videos finales renderizados ───────────────────────────
**/video_*.mp4
**/video_*.webm
**/ai_clip_*.mp4
**/preview_*.mp4

# ── Archivos de test y scripts de desarrollo ──────────────
test_*.js
test_*.wav
test_*.txt
debug_*.js
fix*.js
fix*.cjs
inject*.js
inject*.cjs
append*.cjs
replace*.cjs
upgrade*.js
upgrade*.cjs
apply*.js
do_hook*.js
do_hook*.cjs
*_backup.js
*_old.js
*_new.js
t*.txt

# ── Frames temporales de video ────────────────────────────
temp_frames/
frame_*.jpg
frame_*.png

# ── Outputs públicos generados ────────────────────────────
public/outputs/*
!public/outputs/.gitkeep

# ── Imágenes de test de broll ─────────────────────────────
test_broll_images/

# ── Archivos de backup ────────────────────────────────────
*.bak
*.backup
